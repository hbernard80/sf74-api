{% extends 'base.html.twig' %}

{% set page_title = ('feature.category'|trans({'%count%': 1}, 'main'))|capitalize %}

{% block title %}{{ page_title }} - {{ parent() }}{% endblock %}

{% block body %}
    <h1 class="border-bottom mb-4">{{ page_title }} : {{ category.name }}</h1>

    <div class="table-responsive">
        <table class="table table-hover table-striped table-bordered">
            <tbody>
                <tr>
                   <th>{{ 'global.id'|trans({}, 'forms')|capitalize }}</th>
                    <td>{{ category.id }}</td>
                </tr>
                <tr>
                    <th>{{ 'category.fields.name'|trans({}, 'forms')|capitalize }}</th>
                    <td>{{ category.name }}</td>
                </tr>
                <tr>
                    <th>{{ 'category.fields.slug'|trans({}, 'forms')|capitalize }}</th>
                    <td>{{ category.slug }}</td>
                </tr>
                <tr>
                    <th>{{ 'category.fields.description'|trans({}, 'forms')|capitalize }}</th>
                    <td>{{ category.description }}</td>
                </tr>
            </tbody>
        </table>
    </div>

 <nav class="d-flex justify-content-center mt-4 gap-2" aria-label="Actions">
    {% if is_granted('ROLE_ADMIN') %}
       <a href="{{ path('app_category_edit', {'id': category.id}) }}" class="btn btn-success" aria-label="{{ 'action.edit'|trans({}, 'main')|capitalize }}">
            <i class="bi bi-pencil-square" aria-hidden="true"></i>
            <span class="ms-1">
                {{ 'action.edit'|trans({}, 'main')|capitalize }}
            </span>
        </a>
    {% endif %}

    <a href="{{ path('app_category_index') }}" class="btn btn-dark" aria-label="{{ 'action.back_to_list'|trans({}, 'main')|capitalize }}">
        <i class="bi bi-chevron-compact-left" aria-hidden="true"></i>
        <span class="ms-1">
            {{ 'action.back_to_list'|trans({}, 'main')|capitalize }}
        </span>
    </a>
</nav>    
{% endblock %}
