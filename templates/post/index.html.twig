{% extends 'base.html.twig' %}

{% set page_title = ('feature.post'|trans({'%count%': 2}, 'main'))|capitalize %}

{% block title %}{{ page_title }} - {{ parent() }}{% endblock %}

{% block body %}
    <h1 class="border-bottom mb-4">{{ page_title }}</h1>

     <div class="mb-4">
     {% if pager|length > 0 %}
           <div class="btn btn-dark">{{ pager|length }} {{ page_title|lower }}</div>
        {% endif %}
        {% if is_granted('ROLE_AUTHOR') %}
            <a href="{{ path('app_post_new') }}" class="btn btn-success" aria-label="{{ 'action.create'|trans({}, 'main')|capitalize }}">
            <i class="bi bi-plus-circle" aria-hidden="true"></i>
            <span class="ms-1">{{ 'action.create'|trans({}, 'main')|capitalize }}</span>
            </a>
        {% endif %}
    </div>

    {% if pager|length > 0 %}
        <div class="table-responsive">
        <table class="table table-bordered table-striped table-hover">
            <thead>
                <tr>
                    <th>{{ 'action.id'|trans({}, 'main')|capitalize }}</th>
                    <th>{{ 'title'|trans({}, 'post')|capitalize }}</th>
                    <th>{{ 'feature.category'|trans({'%count%': 1}, 'main')|capitalize }}</th>
                    <th><i class="bi bi-person-fill"></i> {{ 'user.role_author'|trans({'%count%': 1}, 'main')|capitalize }}</th>
                    <th><i class="bi bi-calendar3"></i> {{ 'action.date_updated_at'|trans({}, 'main')|capitalize }}</th>
                    <th>{{ 'action.action'|trans({'%count%': 2}, 'main')|capitalize }}</th>
                </tr>
            </thead>
            <tbody>
            {% for post in pager %}
                <tr>
                    <td class="text-center">{{ post.id }}</td>
                    <td> <a href="{{ path('app_post_show', {'id': post.id}) }}">{{ post.title }}</a></td>
                    <td> <a href="{{ path('app_category_show', {'id': post.category.id}) }}">{{ post.category.name }}</a></td>
                    <td>{{ post.author.firstname|capitalize }} {{ post.author.lastname|upper }}</td>
                    <td class="text-center">{{ post.updatedAt ? post.updatedAt|date('d/m/Y H\\hi') : '' }}</td>
                    <td class="text-center">
                       {% if is_granted('ROLE_ADMIN') or (is_granted('ROLE_AUTHOR') and app.user and post.author.id == app.user.id) %}
                           <a href="{{ path('app_post_edit', {'id': post.id}) }}"
                              aria-label="{{ 'action.edit'|trans({}, 'main')|capitalize }}"
                              title="{{ 'action.edit'|trans({}, 'main')|capitalize }}">
                              <i class="bi bi-pencil-square" aria-hidden="true"></i>
                           </a>
                       {% endif %}
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
        </div>

        <nav class="d-flex justify-content-center mt-4" aria-label="Pagination">{{ pagerfanta(pager, { omitFirstPage: true, translation_domain: 'main' }) }}</nav>

   {% else %}
        <div class="alert alert-warning">{{ 'action.no_record'|trans({}, 'main')|capitalize }}.</div>
    {% endif %}
{% endblock %}
