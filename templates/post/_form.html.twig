{{ form_start(form) }}
    {{ form_widget(form) }}

    <div class="d-flex justify-content-center gap-1">
        <button class="btn btn-success">
            <i class="bi bi-floppy" aria-hidden="true"></i>
            {{ button_label|default('action.save')|trans({}, 'main') }}
        </button>

        <a href="{{ path('app_post_index') }}"
           class="btn btn-dark"
           aria-label="{{ 'action.back_to_list'|trans({}, 'main') }}">
            <i class="bi bi-chevron-compact-left" aria-hidden="true"></i>
            <span class="ms-1">
                {{ 'action.back_to_list'|trans({}, 'main') }}
            </span>
        </a>
    </div>
{{ form_end(form) }}

{% if show_delete|default(false) %}
    <div class="d-flex justify-content-center mt-2">
        {{ include('post/_delete_form.html.twig', { post: post }) }}
    </div>
{% endif %}