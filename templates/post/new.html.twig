{% extends 'base.html.twig' %}

{% set page_title =
    ('action.create'|trans({}, 'main')|capitalize)
    ~ ' '
    ~ ('action.one'|trans({}, 'main'))
    ~ ' '
    ~ ('feature.post'|trans({'%count%': 1}, 'main'))
%}

{% block title %}{{ page_title }} - {{ parent() }}{% endblock %}

{% block body %}
    <h1 class="border-bottom mb-4">{{ page_title }}</h1>

    {{ include('post/_form.html.twig') }}
{% endblock %}
