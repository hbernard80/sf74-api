{% extends 'base.html.twig' %}

{% set page_title = ('user.role_user'|trans({'%count%': 1}, 'main'))|capitalize ~ ' : ' ~ ('user.profile'|trans({}, 'main')) %}

{% block title %}{{ page_title }} - {{ parent() }}{% endblock %}

{% block body %}
    <h1 class="border-bottom mb-4">{{ page_title }}</h1>
    {{ dump(user) }}
{% endblock %}